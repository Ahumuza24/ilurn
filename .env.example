# ILURN_ADMIN_SIGNUP_CODE: private code required to create admin accounts.
ILURN_ADMIN_SIGNUP_CODE="replace-me-in-production"

# ILURN_DATABASE_URL: SQLAlchemy database URL. Defaults to sqlite:///./ilurn.sqlite in ilurn-api.
ILURN_DATABASE_URL="sqlite:///./ilurn.sqlite"

# ILURN_EMAIL_HASH_SALT: Salt used before hashing optional parent email values.
ILURN_EMAIL_HASH_SALT="replace-me-in-production"

# ILURN_COOKIE_SECURE: set true in production so auth cookies require HTTPS.
ILURN_COOKIE_SECURE="false"
